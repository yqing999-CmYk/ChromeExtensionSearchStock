{
  "manifest_version": 3,
  "name": "Stock Search",
  "version": "1.0.0",
  "description": "Right-click any stock symbol to search Yahoo Finance",
  "permissions": [
    "contextMenus"
  ],
  "action": {
    "default_title": "Stock Search"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
